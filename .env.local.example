# Resend (https://resend.com) — usado por app/api/lead/route.js
RESEND_API_KEY=re_xxx_your_key_here

# Email que recebe os leads (caixa interna)
LEAD_EMAIL_TO=leads@exemplo.com.br

# Remetente do email — deve ser um endereço de domínio verificado no Resend.
# Para testes, pode usar: SafeMine <onboarding@resend.dev>
# (atenção: nesse modo só envia para o email cadastrado na sua conta Resend)
LEAD_EMAIL_FROM=SafeMine <onboarding@resend.dev>
